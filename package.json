    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^4.1.4",
    "esbuild": "^0.20.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
